#!/bin/sh

set -u

URL="${ZLAN_INSTALL_URL:-https://raw.githubusercontent.com/Wagnee/Tailscale-ZLAN9809M-Hybrid/main/install.sh}"
TEMP="/tmp/zlan-hybrid-update.$$"

cleanup() {
    rm -f "$TEMP"
}
trap cleanup EXIT INT TERM

echo "Baixando instalador oficial..."
if ! wget -O "$TEMP" "$URL"; then
    echo "ERRO: nao foi possivel baixar $URL" >&2
    exit 1
fi

chmod 0700 "$TEMP"
"$TEMP" --update "$@"
